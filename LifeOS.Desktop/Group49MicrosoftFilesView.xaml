<UserControl x:Class="LifeOS.Desktop.Group49MicrosoftFilesView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Background="Transparent">
 <ScrollViewer VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="0,0,8,24">
   <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <StackPanel>
     <TextBlock Text="INTEGRATIONS / MICROSOFT FILES" Foreground="{DynamicResource LifeOS.Brush.Accent}" FontWeight="SemiBold" FontSize="12"/>
     <TextBlock Text="Group 49 · OneDrive + SharePoint" FontSize="30" FontWeight="SemiBold" Margin="0,4,0,0"/>
     <TextBlock Text="Metadata-first, bounded, review-first and read-only through the existing Microsoft provider identity." Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,6,0,0"/>
    </StackPanel>
    <Button Grid.Column="1" Content="Back to Settings" Click="Back_Click" Style="{StaticResource LifeOS.FocusableButton}" VerticalAlignment="Top"/>
   </Grid>
   <Border Style="{StaticResource LifeOS.Card}" Margin="0,18,0,8">
    <StackPanel>
     <TextBlock Text="Microsoft Files capability enabled" FontSize="20" FontWeight="SemiBold"/>
     <TextBlock Text="Existing Microsoft 365 provider · incremental Files.Read + Sites.Read.All · no second registration" Margin="0,7,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
     <WrapPanel Margin="0,12,0,0">
      <Border Background="{DynamicResource LifeOS.Brush.AccentSoft}" BorderBrush="{DynamicResource LifeOS.Brush.Accent}" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="OneDrive · Granted · Read only" FontWeight="SemiBold"/></Border>
      <Border Background="{DynamicResource LifeOS.Brush.AccentSoft}" BorderBrush="{DynamicResource LifeOS.Brush.Accent}" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="SharePoint · Granted · Read only" FontWeight="SemiBold"/></Border>
      <Border Background="{DynamicResource LifeOS.Brush.SurfaceRaised}" BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="External writes · 0" FontWeight="SemiBold"/></Border>
     </WrapPanel>
    </StackPanel>
   </Border>
   <TabControl Margin="0,6,0,0" MinHeight="500">
    <TabItem Header="OneDrive selection">
     <Grid Margin="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Selected drive" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Codie Shannon · OneDrive" Margin="0,8,0,0"/><TextBlock Text="Drive scope: explicitly selected" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/><TextBlock Text="Maximum 200 metadata items · 90-day lookback" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/></StackPanel></Border>
      <Border Grid.Column="1" Style="{StaticResource LifeOS.Card}" Margin="8,0,0,0"><StackPanel><TextBlock Text="Selected folder" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Projects / LifeOS Evidence" Margin="0,8,0,0"/><TextBlock Text="Bounded sync · folders + file metadata only" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/><TextBlock Text="Automatic file-body download: Disabled" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/><TextBlock Text="Last sync: Healthy · Fresh" Margin="0,12,0,0" FontWeight="SemiBold"/></StackPanel></Border>
     </Grid>
    </TabItem>
    <TabItem Header="SharePoint selection">
     <Grid Margin="18"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Selected site" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="LifeOS Delivery Workspace" Margin="0,8,0,0"/><TextBlock Text="Explicit site selection · no tenant-wide ingestion" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/></StackPanel></Border>
      <Border Grid.Column="1" Style="{StaticResource LifeOS.Card}" Margin="8,0,0,0"><StackPanel><TextBlock Text="Selected document library" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Project Documents" Margin="0,8,0,0"/><TextBlock Text="Metadata-first · bounded delta sync" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/><TextBlock Text="Upload / rename / move / delete / sharing: Disabled" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,5,0,0"/></StackPanel></Border>
     </Grid>
    </TabItem>
    <TabItem Header="Recovery state">
     <StackPanel Margin="18">
      <Border Style="{StaticResource LifeOS.Card}"><StackPanel><TextBlock Text="Source recovery remains visible" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Project brief - superseded.docx" Margin="0,10,0,0" FontWeight="SemiBold"/><TextBlock Text="State: Source removed" Margin="0,6,0,0"/><TextBlock Text="Freshness: Source removed · last confirmed 2026-07-17 04:31" Margin="0,4,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/><TextBlock Text="The accepted LifeOS link is retained for review; stale metadata is never presented as current." Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
      <Border Style="{StaticResource LifeOS.Card}"><StackPanel><TextBlock Text="SharePoint access recovery" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Permission lost · Project Documents" Margin="0,10,0,0" FontWeight="SemiBold"/><TextBlock Text="Capability health: Needs attention · sync failed closed" Margin="0,6,0,0"/><TextBlock Text="No existing accepted record was deleted and no stale candidate was converted to current." Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
     </StackPanel>
    </TabItem>
   </TabControl>
  </StackPanel>
 </ScrollViewer>
</UserControl>
