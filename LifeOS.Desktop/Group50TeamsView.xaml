<UserControl x:Class="LifeOS.Desktop.Group50TeamsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Background="Transparent">
 <UserControl.Resources>
  <Style x:Key="G50.Pill" TargetType="Border">
   <Setter Property="Background" Value="{DynamicResource LifeOS.Brush.AccentSoft}"/>
   <Setter Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Accent}"/>
   <Setter Property="BorderThickness" Value="1"/>
   <Setter Property="CornerRadius" Value="8"/>
   <Setter Property="Padding" Value="10,5"/>
   <Setter Property="Margin" Value="0,0,8,0"/>
  </Style>
  <Style x:Key="G50.TabItem" TargetType="TabItem">
   <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextSecondary}"/>
   <Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Padding" Value="15,9"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="TabItem">
      <Border x:Name="Surface" Background="Transparent" BorderBrush="Transparent"
              BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
       <ContentPresenter ContentSource="Header"/>
      </Border>
      <ControlTemplate.Triggers>
       <Trigger Property="IsSelected" Value="True">
        <Setter TargetName="Surface" Property="Background" Value="{DynamicResource LifeOS.Brush.AccentSoft}"/>
        <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextPrimary}"/>
       </Trigger>
      </ControlTemplate.Triggers>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
  <Style x:Key="G50.TabControl" TargetType="TabControl">
   <Setter Property="Background" Value="Transparent"/>
   <Setter Property="BorderThickness" Value="0"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="TabControl">
      <Grid>
       <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
       <Border Background="{DynamicResource LifeOS.Brush.Surface}" BorderBrush="{DynamicResource LifeOS.Brush.Border}"
               BorderThickness="1" CornerRadius="10" Padding="5">
        <TabPanel IsItemsHost="True"/>
       </Border>
       <Border Grid.Row="1" Margin="0,12,0,0" Background="{DynamicResource LifeOS.Brush.Surface}"
               BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18">
        <ContentPresenter ContentSource="SelectedContent"/>
       </Border>
      </Grid>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
 </UserControl.Resources>

 <ScrollViewer VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="0,0,8,24">
   <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <StackPanel>
     <TextBlock Text="INTEGRATIONS / MICROSOFT TEAMS" Foreground="{DynamicResource LifeOS.Brush.Accent}" FontWeight="SemiBold" FontSize="12"/>
     <TextBlock Text="Group 50 · Teams foundation" FontSize="30" FontWeight="SemiBold" Margin="0,4,0,0"/>
     <TextBlock Text="Bounded, source-backed and review-first Teams context through the existing Microsoft provider."
                Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,6,0,0"/>
    </StackPanel>
    <Button Grid.Column="1" Content="Back to Settings" Click="Back_Click"
            Style="{StaticResource LifeOS.FocusableButton}" VerticalAlignment="Top"/>
   </Grid>

   <Border Style="{StaticResource LifeOS.Card}" Margin="0,18,0,14" Padding="18">
    <Grid>
     <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
     <StackPanel>
      <TextBlock Text="Microsoft Teams" FontSize="20" FontWeight="SemiBold"/>
      <TextBlock Text="Existing Microsoft registration · incremental read-only consent · selected teams and channels only"
                 Margin="0,5,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
     </StackPanel>
     <WrapPanel Grid.Column="1" VerticalAlignment="Center">
      <Border Style="{StaticResource G50.Pill}"><TextBlock Text="Teams · Read only" FontWeight="SemiBold"/></Border>
      <Border Style="{StaticResource G50.Pill}"><TextBlock Text="Messages · 30-day window" FontWeight="SemiBold"/></Border>
      <Border Style="{StaticResource G50.Pill}"><TextBlock Text="External writes · 0" FontWeight="SemiBold"/></Border>
     </WrapPanel>
    </Grid>
   </Border>

   <TabControl Style="{StaticResource G50.TabControl}" MinHeight="350">
    <TabItem Header="Team &amp; channel selection" Style="{StaticResource G50.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Selected team" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="LifeOS Delivery" FontSize="15" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <Separator Margin="0,12"/>
        <TextBlock Text="Explicit membership-backed selection"/>
        <TextBlock Text="No tenant-wide Teams ingestion" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Selected channel" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="General · Delivery coordination" FontSize="15" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <Separator Margin="0,12"/>
        <TextBlock Text="Maximum 100 messages · 30-day lookback"/>
        <TextBlock Text="Replies and thread provenance retained" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>

    <TabItem Header="Message &amp; thread proof" Style="{StaticResource G50.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Channel message" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Confirm Group 50 evidence sequence" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Author · Delivery Coordinator" Margin="0,8,0,0"/>
        <TextBlock Text="Fresh · edited state retained" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Reply provenance" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Parent thread reference retained" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="No raw message ID shown in evidence" Margin="0,8,0,0"/>
        <TextBlock Text="No post, reply, reaction or mutation control" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>

    <TabItem Header="Meeting &amp; action review" Style="{StaticResource G50.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Meeting context" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="LifeOS delivery review" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Linked to Work · LifeOS v9 delivery" Margin="0,8,0,0"/>
        <TextBlock Text="Join-link metadata retained; address redacted" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Reviewable suggestion" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Requested document · final Group 50 proof list" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Needs Review · no autonomous task creation" Margin="0,8,0,0"/>
        <TextBlock Text="No Teams action performed" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>

    <TabItem Header="Recovery state" Style="{StaticResource G50.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18" BorderBrush="{DynamicResource LifeOS.Brush.Warning}">
       <StackPanel>
        <TextBlock Text="Channel access lost" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Archived delivery discussion" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Needs attention · synchronization failed closed" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.Warning}"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Retention boundary" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Accepted LifeOS records remain intact" Margin="0,12,0,0"/>
        <TextBlock Text="Stale Teams content is not presented as current" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>
   </TabControl>
  </StackPanel>
 </ScrollViewer>
</UserControl>
