<UserControl x:Class="LifeOS.Desktop.Group51GoogleWorkspaceView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Background="Transparent">
 <UserControl.Resources>
  <Style x:Key="G51.Pill" TargetType="Border">
   <Setter Property="Background" Value="{DynamicResource LifeOS.Brush.AccentSoft}"/>
   <Setter Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Accent}"/>
   <Setter Property="BorderThickness" Value="1"/>
   <Setter Property="CornerRadius" Value="8"/>
   <Setter Property="Padding" Value="10,5"/>
   <Setter Property="Margin" Value="0,0,8,8"/>
  </Style>
  <Style x:Key="G51.TabItem" TargetType="TabItem">
   <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextSecondary}"/>
   <Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Padding" Value="15,9"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="TabItem">
      <Border x:Name="Surface" Background="Transparent" BorderBrush="Transparent"
              BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
       <ContentPresenter ContentSource="Header"/>
      </Border>
      <ControlTemplate.Triggers>
       <Trigger Property="IsSelected" Value="True">
        <Setter TargetName="Surface" Property="Background" Value="{DynamicResource LifeOS.Brush.AccentSoft}"/>
        <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextPrimary}"/>
       </Trigger>
      </ControlTemplate.Triggers>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
  <Style x:Key="G51.TabControl" TargetType="TabControl">
   <Setter Property="Background" Value="Transparent"/>
   <Setter Property="BorderThickness" Value="0"/>
   <Setter Property="Template">
    <Setter.Value>
     <ControlTemplate TargetType="TabControl">
      <Grid>
       <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
       <Border Background="{DynamicResource LifeOS.Brush.Surface}" BorderBrush="{DynamicResource LifeOS.Brush.Border}"
               BorderThickness="1" CornerRadius="10" Padding="5">
        <TabPanel IsItemsHost="True"/>
       </Border>
       <Border Grid.Row="1" Margin="0,12,0,0" Background="{DynamicResource LifeOS.Brush.Surface}"
               BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18">
        <ContentPresenter ContentSource="SelectedContent"/>
       </Border>
      </Grid>
     </ControlTemplate>
    </Setter.Value>
   </Setter>
  </Style>
 </UserControl.Resources>

 <ScrollViewer VerticalScrollBarVisibility="Auto">
  <StackPanel Margin="0,0,8,24">
   <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <StackPanel>
     <TextBlock Text="INTEGRATIONS / GOOGLE WORKSPACE" Foreground="{DynamicResource LifeOS.Brush.Accent}" FontWeight="SemiBold" FontSize="12"/>
     <TextBlock Text="Group 51 · Complete Google Workspace" FontSize="30" FontWeight="SemiBold" Margin="0,4,0,0"/>
     <TextBlock Text="One Google Cloud project, five read-only capabilities and one review-first integration boundary."
                Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,6,0,0"/>
    </StackPanel>
    <Button Grid.Column="1" Content="Back to Settings" Click="Back_Click"
            Style="{StaticResource LifeOS.FocusableButton}" VerticalAlignment="Top"/>
   </Grid>

   <Border Style="{StaticResource LifeOS.Card}" Margin="0,18,0,14" Padding="18">
    <Grid>
     <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
     <StackPanel>
      <TextBlock Text="Google Workspace provider connected" FontSize="20" FontWeight="SemiBold"/>
      <TextBlock Text="Personal identity · address redacted · Desktop loopback OAuth client · credentials remain machine-local"
                 Margin="0,5,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
     </StackPanel>
     <WrapPanel Grid.Column="1" VerticalAlignment="Center">
      <Border Style="{StaticResource G51.Pill}"><TextBlock Text="One project · Complete" FontWeight="SemiBold"/></Border>
      <Border Style="{StaticResource G51.Pill}"><TextBlock Text="Read-only scopes · 5" FontWeight="SemiBold"/></Border>
      <Border Style="{StaticResource G51.Pill}"><TextBlock Text="External writes · 0" FontWeight="SemiBold"/></Border>
     </WrapPanel>
    </Grid>
   </Border>

   <TabControl Style="{StaticResource G51.TabControl}" MinHeight="390">
    <TabItem Header="Capability catalogue" Style="{StaticResource G51.TabItem}">
     <StackPanel>
      <TextBlock Text="Complete-first Google project setup" FontSize="18" FontWeight="SemiBold"/>
      <TextBlock Text="All five planned APIs are enabled in one LifeOS Google Cloud project. Consent remains incremental and read-only."
                 Margin="0,7,0,16" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
      <UniformGrid Columns="5">
       <Border Style="{StaticResource LifeOS.Card}" Margin="0,0,8,0" Padding="14"><StackPanel><TextBlock Text="Gmail API" FontWeight="SemiBold"/><TextBlock Text="Granted · read only" Margin="0,8,0,0"/><TextBlock Text="Messages + threads" Margin="0,6,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
       <Border Style="{StaticResource LifeOS.Card}" Margin="0,0,8,0" Padding="14"><StackPanel><TextBlock Text="Calendar API" FontWeight="SemiBold"/><TextBlock Text="Granted · read only" Margin="0,8,0,0"/><TextBlock Text="Selected calendars" Margin="0,6,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
       <Border Style="{StaticResource LifeOS.Card}" Margin="0,0,8,0" Padding="14"><StackPanel><TextBlock Text="Drive API" FontWeight="SemiBold"/><TextBlock Text="Granted · read only" Margin="0,8,0,0"/><TextBlock Text="Selected folders" Margin="0,6,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
       <Border Style="{StaticResource LifeOS.Card}" Margin="0,0,8,0" Padding="14"><StackPanel><TextBlock Text="People API" FontWeight="SemiBold"/><TextBlock Text="Granted · read only" Margin="0,8,0,0"/><TextBlock Text="Contact candidates" Margin="0,6,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
       <Border Style="{StaticResource LifeOS.Card}" Padding="14"><StackPanel><TextBlock Text="Tasks API" FontWeight="SemiBold"/><TextBlock Text="Granted · read only" Margin="0,8,0,0"/><TextBlock Text="Selected lists" Margin="0,6,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/></StackPanel></Border>
      </UniformGrid>
     </StackPanel>
    </TabItem>

    <TabItem Header="Gmail &amp; Calendar" Style="{StaticResource G51.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Gmail candidate" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Confirm Group 51 provider proof" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Thread provenance · Inbox + Important · attachment metadata only" Margin="0,8,0,0"/>
        <TextBlock Text="No send, draft or attachment-body action" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Google Calendar candidate" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="LifeOS v9 closure review" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Pacific/Auckland · recurrence and conference metadata retained" Margin="0,8,0,0"/>
        <TextBlock Text="No event mutation control" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>

    <TabItem Header="Drive, Contacts &amp; Tasks" Style="{StaticResource G51.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Google Drive" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="LifeOS Group 51 evidence plan.docx" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Selected folder · owner + change reference retained" Margin="0,8,0,0"/>
        <TextBlock Text="File body not downloaded" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Contacts + Tasks" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Delivery Coordinator · reviewable person candidate" FontWeight="SemiBold" Margin="0,12,0,0"/>
        <TextBlock Text="Review Group 51 Google provider evidence · selected task list" Margin="0,8,0,0"/>
        <TextBlock Text="No contact or task writes" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>

    <TabItem Header="Recovery state" Style="{StaticResource G51.TabItem}">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Style="{StaticResource LifeOS.Card}" Padding="18" BorderBrush="{DynamicResource LifeOS.Brush.Warning}">
       <StackPanel>
        <TextBlock Text="Contacts permission revoked" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Needs attention · failed closed" FontWeight="SemiBold" Margin="0,12,0,0" Foreground="{DynamicResource LifeOS.Brush.Warning}"/>
        <TextBlock Text="Stale contact data is not presented as current" Margin="0,8,0,0"/>
       </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource LifeOS.Card}" Padding="18">
       <StackPanel>
        <TextBlock Text="Independent capability health" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="Gmail, Calendar, Drive and Tasks remain healthy" Margin="0,12,0,0"/>
        <TextBlock Text="Disconnect retains accepted LifeOS records" Margin="0,8,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"/>
       </StackPanel>
      </Border>
     </Grid>
    </TabItem>
   </TabControl>
  </StackPanel>
 </ScrollViewer>
</UserControl>
