<Window x:Class="LifeOS.Desktop.IntegrationConnectionReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Integration connection review"
        Width="620"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource LifeOS.Brush.Window}"
        Foreground="{DynamicResource LifeOS.Brush.TextPrimary}"
        AutomationProperties.AutomationId="IntegrationControlCentre.ConnectionReview">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock x:Name="EyebrowText" Text="CONNECTION REVIEW" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource LifeOS.Brush.Accent}" />
            <TextBlock x:Name="TitleText" Text="Review connection action" FontSize="25" FontWeight="SemiBold" Margin="0,5,0,0" />
            <TextBlock x:Name="AccountText" Margin="0,7,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Row="1" Margin="0,18,0,18" Background="{DynamicResource LifeOS.Brush.Surface}" BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel>
                <TextBlock x:Name="SummaryText" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock x:Name="DetailText" Margin="0,10,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" TextWrapping="Wrap" />
                <Border Margin="0,16,0,0" Background="{DynamicResource LifeOS.Brush.SurfaceRaised}" BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="9" Padding="12">
                    <TextBlock Text="This Group 46 proof uses deterministic fictional state only. No browser consent, OAuth token, provider secret, external read or external write occurs." TextWrapping="Wrap" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                </Border>
                <CheckBox x:Name="ConfirmCheckBox" Content="I reviewed the account, current state and effect of this action." Margin="0,16,0,0" Foreground="{DynamicResource LifeOS.Brush.TextPrimary}" Checked="ConfirmCheckBox_Changed" Unchecked="ConfirmCheckBox_Changed" AutomationProperties.AutomationId="IntegrationControlCentre.ConnectionReview.Confirm" />
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="110" Margin="0,0,8,0" Click="CancelButton_Click" Style="{StaticResource LifeOS.FocusableButton}" />
            <Button x:Name="ConfirmButton" Content="Confirm" Width="170" IsEnabled="False" Click="ConfirmButton_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="IntegrationControlCentre.ConnectionReview.Apply" />
        </StackPanel>
    </Grid>
</Window>
