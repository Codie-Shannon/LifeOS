<Window x:Class="LifeOS.Desktop.IntegrationControlCentreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LifeOS — Integration Control Centre"
        Width="1500"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource LifeOS.Brush.Window}"
        Foreground="{DynamicResource LifeOS.Brush.TextPrimary}"
        AutomationProperties.AutomationId="IntegrationControlCentre.Root">
    <Window.Resources>
        <Style x:Key="Integration.Heading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Integration.Subheading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Integration.Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextSecondary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Integration.Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Integration.Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LifeOS.Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>
        <Style x:Key="Integration.Button" TargetType="Button" BasedOn="{StaticResource LifeOS.FocusableButton}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="13,8" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource LifeOS.Brush.SurfaceRaised}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Border}" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource LifeOS.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LifeOS.Brush.AccentSoft}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Accent}" />
                    <Setter Property="BorderThickness" Value="1" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource LifeOS.Brush.Focus}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="INTEGRATIONS / SYSTEM CONTROL" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource LifeOS.Brush.Accent}" />
                <TextBlock Text="Integration Control Centre" FontSize="30" FontWeight="SemiBold" Margin="0,4,0,0" />
                <TextBlock Text="Accounts, provider capabilities, permissions, freshness, recovery and disconnect controls. Fictional proof data only in Group 46." Margin="0,6,0,0" Style="{StaticResource Integration.Body}" />
            </StackPanel>
            <Border Grid.Column="1" Background="{DynamicResource LifeOS.Brush.AccentSoft}" BorderBrush="{DynamicResource LifeOS.Brush.Accent}" BorderThickness="1" CornerRadius="10" Padding="12,8" VerticalAlignment="Top">
                <TextBlock Text="READ-ONLY FOUNDATION · NO LIVE CREDENTIALS" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource LifeOS.Brush.TextPrimary}" />
            </Border>
        </Grid>

        <WrapPanel Grid.Row="1" Margin="0,18,0,8">
            <Border Style="{StaticResource Integration.Card}" Width="215">
                <StackPanel><TextBlock Text="Providers" Style="{StaticResource Integration.Caption}" /><TextBlock x:Name="ProviderCountText" Text="0" FontSize="26" FontWeight="SemiBold" Margin="0,3,0,0" /><TextBlock Text="Permanent catalogue" Style="{StaticResource Integration.Caption}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Integration.Card}" Width="215">
                <StackPanel><TextBlock Text="Connected accounts" Style="{StaticResource Integration.Caption}" /><TextBlock x:Name="AccountCountText" Text="0" FontSize="26" FontWeight="SemiBold" Margin="0,3,0,0" /><TextBlock Text="Personal and work separated" Style="{StaticResource Integration.Caption}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Integration.Card}" Width="215">
                <StackPanel><TextBlock Text="Capability health" Style="{StaticResource Integration.Caption}" /><TextBlock x:Name="CapabilityHealthText" Text="0 healthy" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0" /><TextBlock Text="Calculated per capability" Style="{StaticResource Integration.Caption}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Integration.Card}" Width="215">
                <StackPanel><TextBlock Text="Needs attention" Style="{StaticResource Integration.Caption}" /><TextBlock x:Name="AttentionCountText" Text="0" FontSize="26" FontWeight="SemiBold" Margin="0,3,0,0" /><TextBlock Text="Visible; never silently green" Style="{StaticResource Integration.Caption}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Integration.Card}" Width="215">
                <StackPanel><TextBlock Text="External writes" Style="{StaticResource Integration.Caption}" /><TextBlock Text="0" FontSize="26" FontWeight="SemiBold" Margin="0,3,0,0" /><TextBlock Text="Disabled for Group 46" Style="{StaticResource Integration.Caption}" /></StackPanel>
            </Border>
        </WrapPanel>

        <TabControl Grid.Row="2" x:Name="ControlTabs" Background="Transparent" BorderBrush="{DynamicResource LifeOS.Brush.Border}" AutomationProperties.AutomationId="IntegrationControlCentre.Tabs">
            <TabItem Header="Overview" AutomationProperties.AutomationId="IntegrationControlCentre.Tab.Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Provider catalogue" Style="{StaticResource Integration.Heading}" />
                        <TextBlock Text="Every provider exposes the same account, permission, health, audit and recovery contract." Margin="0,5,0,12" Style="{StaticResource Integration.Body}" />
                        <ItemsControl x:Name="ProviderItems">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Integration.Card}" Width="405" MinHeight="160">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Integration.Subheading}" />
                                                <Border Grid.Column="1" Background="{DynamicResource LifeOS.Brush.SurfaceRaised}" BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="8,4"><TextBlock Text="FICTIONAL" FontSize="11" FontWeight="SemiBold" /></Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Description}" Margin="0,8,0,10" Style="{StaticResource Integration.Body}" />
                                            <TextBlock Text="{Binding Summary}" Style="{StaticResource Integration.Caption}" />
                                            <TextBlock Text="{Binding CapabilitySummary}" Margin="0,4,0,0" Style="{StaticResource Integration.Caption}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Connected accounts" Margin="0,12,0,0" Style="{StaticResource Integration.Heading}" />
                        <TextBlock Text="Classification is explicit and retained independently for each provider identity." Margin="0,5,0,12" Style="{StaticResource Integration.Body}" />
                        <ItemsControl x:Name="OverviewAccountItems">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Integration.Card}" Width="405" MinHeight="145">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Integration.Subheading}" />
                                            <TextBlock Text="{Binding ProviderName}" Margin="0,4,0,0" Style="{StaticResource Integration.Body}" />
                                            <TextBlock Text="{Binding Identity}" Margin="0,3,0,0" Style="{StaticResource Integration.Caption}" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Border Background="{DynamicResource LifeOS.Brush.AccentSoft}" BorderBrush="{DynamicResource LifeOS.Brush.Accent}" BorderThickness="1" CornerRadius="8" Padding="9,5" Margin="0,0,8,0"><TextBlock Text="{Binding Classification}" FontWeight="SemiBold" /></Border>
                                                <Border Background="{DynamicResource LifeOS.Brush.SurfaceRaised}" BorderBrush="{DynamicResource LifeOS.Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="9,5"><TextBlock Text="{Binding ConnectionState}" FontWeight="SemiBold" /></Border>
                                            </WrapPanel>
                                            <TextBlock Text="{Binding FreshnessSummary}" Margin="0,9,0,0" Style="{StaticResource Integration.Caption}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Capabilities &amp; permissions" AutomationProperties.AutomationId="IntegrationControlCentre.Tab.Capabilities">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="310" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Integration.Card}" Margin="0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Accounts" Style="{StaticResource Integration.Heading}" Margin="0,0,0,12" />
                            <ListBox x:Name="AccountListBox" BorderThickness="0" Background="Transparent" SelectionChanged="AccountListBox_SelectionChanged" AutomationProperties.AutomationId="IntegrationControlCentre.Accounts">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ClassificationAndProvider}" Margin="0,3,0,0" Style="{StaticResource Integration.Caption}" />
                                            <TextBlock Text="{Binding ConnectionState}" Margin="0,3,0,0" Style="{StaticResource Integration.Caption}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Integration.Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="SelectedAccountNameText" Text="Select an account" Style="{StaticResource Integration.Heading}" />
                                            <TextBlock x:Name="SelectedAccountIdentityText" Margin="0,4,0,0" Style="{StaticResource Integration.Body}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock x:Name="SelectedAccountClassText" Text="—" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                            <TextBlock x:Name="SelectedAccountStateText" Text="—" Margin="0,4,0,0" HorizontalAlignment="Right" Style="{StaticResource Integration.Caption}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock x:Name="SelectedAccountSyncText" Margin="0,10,0,0" Style="{StaticResource Integration.Caption}" />
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button x:Name="RefreshActionButton" Content="Refresh" Click="RefreshButton_Click" Style="{StaticResource Integration.Button}" AutomationProperties.AutomationId="IntegrationControlCentre.Action.Refresh" />
                                        <Button x:Name="ReconnectActionButton" Content="Reconnect review" Click="ReconnectButton_Click" Style="{StaticResource Integration.Button}" AutomationProperties.AutomationId="IntegrationControlCentre.Action.Reconnect" />
                                        <Button x:Name="RevokeActionButton" Content="Revoke review" Click="RevokeButton_Click" Style="{StaticResource Integration.Button}" AutomationProperties.AutomationId="IntegrationControlCentre.Action.Revoke" />
                                        <Button x:Name="DisconnectActionButton" Content="Disconnect review" Click="DisconnectButton_Click" Style="{StaticResource Integration.Button}" AutomationProperties.AutomationId="IntegrationControlCentre.Action.Disconnect" />
                                    </WrapPanel>
                                    <TextBlock x:Name="ActionStatusText" Margin="0,10,0,0" Style="{StaticResource Integration.Body}" AutomationProperties.LiveSetting="Polite" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Per-capability health" Style="{StaticResource Integration.Heading}" />
                            <TextBlock Text="One stale or missing capability does not falsely convert the entire provider into a healthy state." Margin="0,5,0,10" Style="{StaticResource Integration.Body}" />
                            <ItemsControl x:Name="CapabilityItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Integration.Card}" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="150" /><ColumnDefinition Width="150" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="{Binding CapabilityId}" Style="{StaticResource Integration.Caption}" /></StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Health}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="{Binding Freshness}" VerticalAlignment="Center" Style="{StaticResource Integration.Body}" />
                                                <StackPanel Grid.Column="3"><TextBlock Text="{Binding LastSuccess}" Style="{StaticResource Integration.Caption}" /><TextBlock Text="{Binding Detail}" Margin="0,3,0,0" Style="{StaticResource Integration.Caption}" /></StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Permission catalogue" Margin="0,12,0,0" Style="{StaticResource Integration.Heading}" />
                            <TextBlock Text="Required/optional status is separate from granted, missing, revoked and not-requested consent state." Margin="0,5,0,10" Style="{StaticResource Integration.Body}" />
                            <ItemsControl x:Name="PermissionItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Integration.Card}" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="130" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions>
                                                <StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="{Binding Capability}" Style="{StaticResource Integration.Caption}" /></StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Requirement}" VerticalAlignment="Center" Style="{StaticResource Integration.Body}" />
                                                <TextBlock Grid.Column="2" Text="{Binding State}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Audit history" AutomationProperties.AutomationId="IntegrationControlCentre.Tab.Audit">
                <Grid Margin="16">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Connector audit history" Style="{StaticResource Integration.Heading}" />
                        <TextBlock Text="Consent, sync, permission, reconnect, revoke and disconnect decisions remain ordered and reviewable. Diagnostics are sanitized." Margin="0,5,0,12" Style="{StaticResource Integration.Body}" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AuditItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Integration.Card}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="175" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /><ColumnDefinition Width="90" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Timestamp}" Style="{StaticResource Integration.Caption}" />
                                            <StackPanel Grid.Column="1"><TextBlock Text="{Binding Action}" FontWeight="SemiBold" /><TextBlock Text="{Binding Account}" Style="{StaticResource Integration.Caption}" /></StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Summary}" Style="{StaticResource Integration.Body}" />
                                            <TextBlock Grid.Column="3" Text="{Binding Result}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock Text="Local state: %LOCALAPPDATA%\LifeOS\integration-control-centre.json · No OAuth token, client secret or authorization code is stored in this model." VerticalAlignment="Center" Style="{StaticResource Integration.Caption}" />
            <Button Grid.Column="1" Content="Close" Click="CloseButton_Click" Style="{StaticResource Integration.Button}" Margin="12,0,0,0" AutomationProperties.AutomationId="IntegrationControlCentre.Close" />
        </Grid>
    </Grid>
</Window>
