<Window x:Class="LifeOS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LifeOS Desktop"
        Height="760"
        Width="1240"
        MinHeight="640"
        MinWidth="1020"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#020617"
                BorderBrush="#1E293B"
                BorderThickness="0,0,1,0"
                Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="LifeOS"
                               Foreground="#F8FAFC"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Weekly pressure command centre"
                               Foreground="#94A3B8"
                               FontSize="13"
                               Margin="0,4,0,20"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Background="#0F172A"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Desktop v5.0.0-beta.1"
                                   Foreground="#E2E8F0"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="v5 integration release checkpoint: local imports, Calendar, Gmail, Integration Inbox and Email Radar remain manual, read-only and review-first. No external or LifeOS operational mutation occurs automatically."
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,12">
                    <StackPanel>
                        <Button x:Name="CommandCentreNavButton"
                                Content="Command Centre"
                                Style="{StaticResource NavButtonStyle}"
                                Click="CommandCentreNavButton_Click"/>

                        <Button x:Name="MoneyPressureNavButton"
                                Content="Money Pressure"
                                Style="{StaticResource NavButtonStyle}"
                                Click="MoneyPressureNavButton_Click"/>

                        <Button x:Name="MoneyTimelineNavButton"
                                Content="Money Timeline"
                                Style="{StaticResource NavButtonStyle}"
                                Click="MoneyTimelineNavButton_Click"/>

                        <Button x:Name="BillsPaymentsNavButton"
                                Content="Bills / Payments"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BillsPaymentsNavButton_Click"/>

                        <Button x:Name="MoneyProfileNavButton"
                                Content="Money Profile"
                                Style="{StaticResource NavButtonStyle}"
                                Click="MoneyProfileNavButton_Click"/>

                        <Button x:Name="AgendaNavButton"
                                Content="Agenda"
                                Style="{StaticResource NavButtonStyle}"
                                Click="AgendaNavButton_Click"/>

                        <Button x:Name="PaymentCalendarNavButton"
                                Content="Payment Calendar"
                                Style="{StaticResource NavButtonStyle}"
                                Click="PaymentCalendarNavButton_Click"/>

                        <Button x:Name="PayLaterNavButton"
                                Content="Pay Later"
                                Style="{StaticResource NavButtonStyle}"
                                Click="PayLaterNavButton_Click"/>

                        <Button x:Name="WeeklyCloseOutNavButton"
                                Content="Weekly Close-Out"
                                Style="{StaticResource NavButtonStyle}"
                                Click="WeeklyCloseOutNavButton_Click"/>

                        <Button x:Name="WorkSessionsNavButton"
                                Content="Work Sessions"
                                Style="{StaticResource NavButtonStyle}"
                                Click="WorkSessionsNavButton_Click"/>

                        <Button x:Name="PaidWorkCentreNavButton"
                                Content="Paid Work Centre"
                                Style="{StaticResource NavButtonStyle}"
                                Click="PaidWorkCentreNavButton_Click"/>

                        <Button x:Name="ProofTrackerNavButton"
                                Content="Proof Tracker"
                                Style="{StaticResource NavButtonStyle}"
                                Click="ProofTrackerNavButton_Click"/>

                        <Button x:Name="FollowUpsNavButton"
                                Content="Follow-Ups"
                                Style="{StaticResource NavButtonStyle}"
                                Click="FollowUpsNavButton_Click"/>

                        <Button x:Name="WorkPipelineNavButton"
                                Content="Work Pipeline"
                                Style="{StaticResource NavButtonStyle}"
                                Click="WorkPipelineNavButton_Click"/>

                        <Button x:Name="ReceiptEvidenceNavButton"
                                Content="Receipt OCR / Evidence"
                                Style="{StaticResource NavButtonStyle}"
                                Click="ReceiptEvidenceNavButton_Click"/>

                        <Button x:Name="IntegrationInboxNavButton"
                                Content="Integration Inbox"
                                Style="{StaticResource NavButtonStyle}"
                                Click="IntegrationInboxNavButton_Click"/>

                        <Button x:Name="EmailRadarNavButton"
                                Content="Email Radar"
                                Style="{StaticResource NavButtonStyle}"
                                Click="EmailRadarNavButton_Click"/>

                        <Button x:Name="DailyOperatingFlowNavButton"
                                Content="Daily Operating Flow"
                                Style="{StaticResource NavButtonStyle}"
                                Click="DailyOperatingFlowNavButton_Click"/>

                        <Button x:Name="DailyStateNavButton"
                                Content="Daily State"
                                Style="{StaticResource NavButtonStyle}"
                                Click="DailyStateNavButton_Click"/>

                        <Button x:Name="TimesheetEvidenceNavButton"
                                Content="Timesheet Evidence"
                                Style="{StaticResource NavButtonStyle}"
                                Click="TimesheetEvidenceNavButton_Click"/>

                        <Button x:Name="EvidenceVaultNavButton"
                                Content="Evidence Vault"
                                Style="{StaticResource NavButtonStyle}"
                                Click="EvidenceVaultNavButton_Click"/>

                        <Button x:Name="RelationshipRadarNavButton"
                                Content="Relationship Radar"
                                Style="{StaticResource NavButtonStyle}"
                                Click="RelationshipRadarNavButton_Click"/>

                        <Button x:Name="ProjectsNavButton"
                                Content="Projects"
                                Style="{StaticResource NavButtonStyle}"
                                Click="ProjectsNavButton_Click"/>

                        <Button x:Name="TimerAgentNavButton"
                                Content="TimerAgent"
                                Style="{StaticResource NavButtonStyle}"
                                Click="TimerAgentNavButton_Click"/>

                        <Button x:Name="ItemStateEngineNavButton"
                                Content="Item State Engine"
                                Style="{StaticResource NavButtonStyle}"
                                Click="ItemStateEngineNavButton_Click"/>

                        <Button x:Name="LifeOsSpineNavButton"
                                Content="LifeOS Spine Map"
                                Style="{StaticResource NavButtonStyle}"
                                Click="LifeOsSpineNavButton_Click"/>

                        <Button x:Name="FinalOfflineOsNavButton"
                                Content="Final Offline OS"
                                Style="{StaticResource NavButtonStyle}"
                                Click="FinalOfflineOsNavButton_Click"/>

                        <Button x:Name="SearchKnowledgeNavButton"
                                Content="Search / Knowledge"
                                Style="{StaticResource NavButtonStyle}"
                                Click="SearchKnowledgeNavButton_Click"/>

                        <Button x:Name="OsNavigationNavButton"
                                Content="OS Navigation"
                                Style="{StaticResource NavButtonStyle}"
                                Click="OsNavigationNavButton_Click"/>

                        <Button x:Name="UniversalSpineNavButton"
                                Content="Universal Spine"
                                Style="{StaticResource NavButtonStyle}"
                                Click="UniversalSpineNavButton_Click"/>

                        <Button x:Name="DesktopReleaseNavButton"
                                Content="Desktop Release"
                                Style="{StaticResource NavButtonStyle}"
                                Click="DesktopReleaseNavButton_Click"/>

                        <Button x:Name="SettingsNavButton"
                                Content="Settings / Safety"
                                Style="{StaticResource NavButtonStyle}"
                                Click="SettingsNavButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="#0F172A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0B1120"
                    BorderBrush="#1E293B"
                    BorderThickness="0,0,0,1"
                    Padding="28,20">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="PageTitleTextBlock"
                                   Text="Command Centre"
                                   Foreground="#F8FAFC"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="PageSubtitleTextBlock"
                                   Text="Work, income, proof command centre • Desktop v1.4"
                                   Foreground="#94A3B8"
                                   FontSize="14"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            Background="#111827"
                            BorderBrush="#243244"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="14,8">
                        <TextBlock x:Name="CurrentSectionTextBlock"
                                   Text="Current section: Command Centre"
                                   Foreground="#CBD5E1"
                                   FontSize="13"/>
                    </Border>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28">
                <ContentControl x:Name="MainContentControl"/>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="#0B1120"
                    BorderBrush="#1E293B"
                    BorderThickness="0,1,0,0"
                    Padding="28,10">
                <TextBlock Text="LifeOS Desktop v5.0.0-beta.1 unifies local imports, Google Calendar, Gmail, Integration Inbox, and Email Radar into one manual, read-only, review-first integration checkpoint."
                           Foreground="#64748B"
                           FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</Window>
