<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="LifeOS.Color.Accent">#8B5CF6</Color>
    <SolidColorBrush x:Key="LifeOS.Brush.Window" Color="#090B12" />
    <SolidColorBrush x:Key="LifeOS.Brush.Rail" Color="#10121C" />
    <SolidColorBrush x:Key="LifeOS.Brush.TopBar" Color="#11131E" />
    <SolidColorBrush x:Key="LifeOS.Brush.Surface" Color="#151824" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceRaised" Color="#1B1E2C" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceHover" Color="#24283A" />
    <SolidColorBrush x:Key="LifeOS.Brush.Border" Color="#303447" />
    <SolidColorBrush x:Key="LifeOS.Brush.BorderStrong" Color="#484D65" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextPrimary" Color="#F8FAFC" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextSecondary" Color="#B9C0D5" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextMuted" Color="#8E96AD" />
    <SolidColorBrush x:Key="LifeOS.Brush.Accent" Color="{StaticResource LifeOS.Color.Accent}" />
    <SolidColorBrush x:Key="LifeOS.Brush.AccentSoft" Color="#348B5CF6" />
    <SolidColorBrush x:Key="LifeOS.Brush.Focus" Color="{StaticResource LifeOS.Color.Accent}" />
    <SolidColorBrush x:Key="LifeOS.Brush.Success" Color="#4ADE80" />
    <SolidColorBrush x:Key="LifeOS.Brush.Warning" Color="#FBBF24" />
    <SolidColorBrush x:Key="LifeOS.Brush.Danger" Color="#FB7185" />
    <SolidColorBrush x:Key="LifeOS.Brush.Overlay" Color="#C9000000" />
  <SolidColorBrush x:Key="LifeOS.Brush.Input" Color="#1B1C28"/>
  <SolidColorBrush x:Key="LifeOS.Brush.InputText" Color="#F5F3FF"/>
  <!-- Group 45 native ComboBox system-colour hotfix -->

  <!-- Native WPF ComboBox closed and popup surfaces -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.WindowBrushKey}"
      Color="#1B1C28"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.WindowTextBrushKey}"
      Color="#F5F3FF"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.ControlBrushKey}"
      Color="#1B1C28"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.ControlTextBrushKey}"
      Color="#F5F3FF"/>

  <!-- Hovered or keyboard-highlighted option -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.HighlightBrushKey}"
      Color="#252638"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
      Color="#F5F3FF"/>

  <!-- Selected item when another row is being hovered -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
      Color="#1B1C28"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
      Color="#F5F3FF"/>

  <!-- Disabled dropdown text -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.GrayTextBrushKey}"
      Color="#A9A8B7"/>

  <!-- Popup/menu option colours -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.MenuBrushKey}"
      Color="#1B1C28"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.MenuTextBrushKey}"
      Color="#F5F3FF"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.MenuHighlightBrushKey}"
      Color="#252638"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.HotTrackBrushKey}"
      Color="#A78BFA"/>

  <!-- /Group 45 native ComboBox system-colour hotfix -->
</ResourceDictionary>
