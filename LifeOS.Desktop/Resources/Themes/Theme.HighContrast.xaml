<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="LifeOS.Color.Accent">#FFFF00</Color>
    <SolidColorBrush x:Key="LifeOS.Brush.Window" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.Rail" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.TopBar" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.Surface" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceRaised" Color="#101010" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceHover" Color="#202020" />
    <SolidColorBrush x:Key="LifeOS.Brush.Border" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.BorderStrong" Color="#FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextPrimary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextSecondary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextMuted" Color="#E5E5E5" />
    <SolidColorBrush x:Key="LifeOS.Brush.Accent" Color="{StaticResource LifeOS.Color.Accent}" />
    <SolidColorBrush x:Key="LifeOS.Brush.AccentSoft" Color="#44FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Focus" Color="#FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Success" Color="#00FF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Warning" Color="#FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Danger" Color="#FF4D4D" />
    <SolidColorBrush x:Key="LifeOS.Brush.Overlay" Color="#E6000000" />
  <SolidColorBrush x:Key="LifeOS.Brush.Input" Color="#101010"/>
  <SolidColorBrush x:Key="LifeOS.Brush.InputText" Color="#FFFFFF"/>
  <!-- Group 45 native ComboBox system-colour hotfix -->

  <!-- Native WPF ComboBox closed and popup surfaces -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.WindowBrushKey}"
      Color="#101010"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.WindowTextBrushKey}"
      Color="#FFFFFF"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.ControlBrushKey}"
      Color="#101010"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.ControlTextBrushKey}"
      Color="#FFFFFF"/>

  <!-- Hovered or keyboard-highlighted option -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.HighlightBrushKey}"
      Color="#202020"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
      Color="#FFFFFF"/>

  <!-- Selected item when another row is being hovered -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
      Color="#101010"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
      Color="#FFFFFF"/>

  <!-- Disabled dropdown text -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.GrayTextBrushKey}"
      Color="#E5E5E5"/>

  <!-- Popup/menu option colours -->
  <SolidColorBrush
      x:Key="{x:Static SystemColors.MenuBrushKey}"
      Color="#101010"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.MenuTextBrushKey}"
      Color="#FFFFFF"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.MenuHighlightBrushKey}"
      Color="#202020"/>

  <SolidColorBrush
      x:Key="{x:Static SystemColors.HotTrackBrushKey}"
      Color="#FFFF00"/>

  <!-- /Group 45 native ComboBox system-colour hotfix -->
</ResourceDictionary>
