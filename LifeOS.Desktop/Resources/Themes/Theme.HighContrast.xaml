<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="LifeOS.Color.Accent">#FFFF00</Color>
    <SolidColorBrush x:Key="LifeOS.Brush.Window" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.Rail" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.TopBar" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.Surface" Color="#000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceRaised" Color="#101010" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceHover" Color="#202020" />
    <SolidColorBrush x:Key="LifeOS.Brush.Border" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.BorderStrong" Color="#FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextPrimary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextSecondary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextMuted" Color="#E5E5E5" />
    <SolidColorBrush x:Key="LifeOS.Brush.Accent" Color="{StaticResource LifeOS.Color.Accent}" />
    <SolidColorBrush x:Key="LifeOS.Brush.AccentSoft" Color="#44FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Focus" Color="#FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Success" Color="#00FF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Warning" Color="#FFFF00" />
    <SolidColorBrush x:Key="LifeOS.Brush.Danger" Color="#FF4D4D" />
    <SolidColorBrush x:Key="LifeOS.Brush.Overlay" Color="#E6000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.Input" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.InputText" Color="#000000" />
</ResourceDictionary>
