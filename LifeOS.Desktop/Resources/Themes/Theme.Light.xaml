<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="LifeOS.Color.Accent">#7C3AED</Color>
    <SolidColorBrush x:Key="LifeOS.Brush.Window" Color="#F5F5FA" />
    <SolidColorBrush x:Key="LifeOS.Brush.Rail" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.TopBar" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceRaised" Color="#FAFAFE" />
    <SolidColorBrush x:Key="LifeOS.Brush.SurfaceHover" Color="#EFEFFD" />
    <SolidColorBrush x:Key="LifeOS.Brush.Border" Color="#D8DAE7" />
    <SolidColorBrush x:Key="LifeOS.Brush.BorderStrong" Color="#B9BDCF" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextPrimary" Color="#111827" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextSecondary" Color="#4B5563" />
    <SolidColorBrush x:Key="LifeOS.Brush.TextMuted" Color="#6B7280" />
    <SolidColorBrush x:Key="LifeOS.Brush.Accent" Color="{StaticResource LifeOS.Color.Accent}" />
    <SolidColorBrush x:Key="LifeOS.Brush.AccentSoft" Color="#247C3AED" />
    <SolidColorBrush x:Key="LifeOS.Brush.Focus" Color="{StaticResource LifeOS.Color.Accent}" />
    <SolidColorBrush x:Key="LifeOS.Brush.Success" Color="#15803D" />
    <SolidColorBrush x:Key="LifeOS.Brush.Warning" Color="#B45309" />
    <SolidColorBrush x:Key="LifeOS.Brush.Danger" Color="#BE123C" />
    <SolidColorBrush x:Key="LifeOS.Brush.Overlay" Color="#99000000" />
    <SolidColorBrush x:Key="LifeOS.Brush.Input" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LifeOS.Brush.InputText" Color="#111827" />
</ResourceDictionary>
