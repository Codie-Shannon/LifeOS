<Window x:Class="LifeOS.Desktop.V8ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LifeOS Desktop v8"
        Width="1360"
        Height="820"
        MinWidth="840"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        AutomationProperties.AutomationId="LifeOS.V8.Shell">
    <Grid Background="{DynamicResource LifeOS.Brush.Window}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="ContextColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="{DynamicResource LifeOS.Brush.Rail}"
                BorderBrush="{DynamicResource LifeOS.Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" Height="64" ToolTip="LifeOS">
                    <Border Width="38"
                            Height="38"
                            CornerRadius="10"
                            Background="{DynamicResource LifeOS.Brush.Accent}">
                        <Path Data="M 11,7 L 17,7 L 17,25 L 29,25 L 29,31 L 11,31 Z M 20,7 L 26,7 L 26,21 L 20,21 Z"
                              Fill="White"
                              Stretch="Uniform"
                              Margin="5"/>
                    </Border>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="8,8,8,12">
                        <Button x:Name="HomeNav" Tag="Home" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Home">
                            <StackPanel><TextBlock FontSize="19" Text="⌂" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Home" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="WorkNav" Tag="Work" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Work">
                            <StackPanel><TextBlock FontSize="19" Text="▣" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Work" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="CareerNav" Tag="Career" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Career">
                            <StackPanel><TextBlock FontSize="19" Text="◆" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Career" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="MoneyNav" Tag="Money" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Money">
                            <StackPanel><TextBlock FontSize="19" Text="$" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Money" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="LifeNav" Tag="Life" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Life">
                            <StackPanel><TextBlock FontSize="19" Text="♥" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Life" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="ProjectsNav" Tag="Projects" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Projects">
                            <StackPanel><TextBlock FontSize="19" Text="◇" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Projects" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="AssistantNav" Tag="Assistant" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Assistant">
                            <StackPanel><TextBlock FontSize="19" Text="✦" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Assistant" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                        <Button x:Name="SettingsNav" Tag="Settings" Click="WorkspaceNav_Click" Style="{StaticResource LifeOS.FocusableButton}" AutomationProperties.AutomationId="Nav.Settings">
                            <StackPanel><TextBlock FontSize="19" Text="⚙" HorizontalAlignment="Center"/><TextBlock FontSize="11" Text="Settings" HorizontalAlignment="Center"/></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="{DynamicResource LifeOS.Brush.Surface}"
                BorderBrush="{DynamicResource LifeOS.Brush.Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="WorkspaceTitle" FontSize="17" FontWeight="SemiBold" Text="Home"/>
                    <TextBlock x:Name="WorkspaceSubtitle" FontSize="11" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="Balanced operating overview"/>
                </StackPanel>

                <Button x:Name="CommandButton"
                        Grid.Column="1"
                        Width="360"
                        MaxWidth="420"
                        Height="52"
                        Style="{StaticResource LifeOS.FocusableButton}"
                        Click="CommandButton_Click"
                        AutomationProperties.AutomationId="TopBar.Command">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="Search or run a command"/>
                        <TextBlock Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="Ctrl+K"/>
                    </Grid>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource LifeOS.FocusableButton}" Margin="4,0" Content="Review 4" Click="ReviewButton_Click" AutomationProperties.AutomationId="TopBar.Review"/>
                    <Button Style="{StaticResource LifeOS.FocusableButton}" Margin="4,0" Content="● Synced" Click="StatusButton_Click" AutomationProperties.AutomationId="TopBar.Status"/>
                    <Button x:Name="StopButton" Style="{StaticResource LifeOS.FocusableButton}" Margin="4,0" Content="Stop" Click="StopButton_Click" AutomationProperties.AutomationId="TopBar.EmergencyStop"/>
                    <Button Style="{StaticResource LifeOS.FocusableButton}" Margin="4,0" Content="CS ▾" Click="ProfileButton_Click" AutomationProperties.AutomationId="TopBar.Profile"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Grid.Row="1">
            <ScrollViewer x:Name="WorkspaceScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          AutomationProperties.AutomationId="Workspace.Scroll">
                <StackPanel x:Name="WorkspaceRoot" Margin="24" AutomationProperties.AutomationId="Workspace.Content">
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="WorkspaceEyebrow" Style="{StaticResource LifeOS.SectionTitle}" Text="TODAY / PRESSURE / WORK / MONEY"/>
                            <TextBlock x:Name="WorkspaceDisplayTitle" Margin="0,10,0,4" Style="{StaticResource LifeOS.PageTitle}" Text="Good afternoon, Codie."/>
                            <TextBlock x:Name="WorkspaceDescription" MaxWidth="960" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" FontSize="14" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Top">
                            <Button x:Name="DensityButton" Style="{StaticResource LifeOS.FocusableButton}" Content="Use Compact" Click="DensityButton_Click" AutomationProperties.AutomationId="Workspace.DensityToggle"/>
                            <TextBlock x:Name="DensityStatusText" Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="Comfortable density"/>
                        </StackPanel>
                    </Grid>

                    <ItemsControl x:Name="MetricItems" Margin="0,0,0,8" AutomationProperties.AutomationId="Workspace.Metrics">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Tag="WorkspaceMetricCard" Style="{StaticResource LifeOS.Card}" Width="220" Margin="0,0,12,12">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LifeOS.SectionTitle}" Text="{Binding Label}"/>
                                        <TextBlock Margin="0,10,0,4" Style="{StaticResource LifeOS.CardHeadline}" Text="{Binding Value}" TextWrapping="Wrap"/>
                                        <TextBlock Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" FontSize="12" Text="{Binding Detail}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl x:Name="SectionItems" AutomationProperties.AutomationId="Workspace.Sections">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock FontSize="19" FontWeight="SemiBold" Text="{Binding Title}"/>
                                    <TextBlock Margin="0,5,0,12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding Modules}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Tag="WorkspaceModuleCard"
                                                        Style="{StaticResource LifeOS.Card}"
                                                        Width="348"
                                                        Margin="0,0,12,12"
                                                        AutomationProperties.AutomationId="{Binding AutomationId}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource LifeOS.SectionTitle}" Text="{Binding Status}"/>
                                                        <TextBlock Margin="0,10,0,6" Style="{StaticResource LifeOS.CardHeadline}" Text="{Binding Title}" TextWrapping="Wrap"/>
                                                        <TextBlock MinHeight="48" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="{Binding Description}" TextWrapping="Wrap"/>
                                                        <Button Margin="0,14,0,0"
                                                                HorizontalAlignment="Left"
                                                                Style="{StaticResource LifeOS.FocusableButton}"
                                                                Content="{Binding ActionLabel}"
                                                                Tag="{Binding RouteId}"
                                                                IsEnabled="{Binding CanOpen}"
                                                                Click="OpenModule_Click"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="2"
                Grid.RowSpan="2"
                Background="{DynamicResource LifeOS.Brush.Surface}"
                BorderBrush="{DynamicResource LifeOS.Brush.Border}"
                BorderThickness="1,0,0,0">
            <DockPanel Margin="18">
                <Button DockPanel.Dock="Top" HorizontalAlignment="Right" Style="{StaticResource LifeOS.FocusableButton}" Content="×" Click="ContextButton_Click" AutomationProperties.AutomationId="Context.Close"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,18,0,0">
                        <TextBlock Style="{StaticResource LifeOS.SectionTitle}" Text="CONTEXT"/>
                        <TextBlock x:Name="ContextTitle" Margin="0,12,0,8" Style="{StaticResource LifeOS.CardHeadline}" Text="Home context"/>
                        <TextBlock x:Name="ContextBody" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" TextWrapping="Wrap"/>
                        <Separator Margin="0,18" Background="{DynamicResource LifeOS.Brush.Border}"/>
                        <TextBlock FontWeight="SemiBold" Text="Workspace contents"/>
                        <ItemsControl x:Name="ContextModulesList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,8" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Text="{Binding}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Separator Margin="0,10,0,18" Background="{DynamicResource LifeOS.Brush.Border}"/>
                        <TextBlock FontWeight="SemiBold" Text="Migration boundary"/>
                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" TextWrapping="Wrap" Text="Focused v8 workspace routes open the canonical preserved module and record store. Legacy routes remain internal through Group 44 and are removed in Group 45."/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border x:Name="CommandOverlay"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Panel.ZIndex="1000"
                Visibility="Collapsed"
                Background="#99000000"
                AutomationProperties.AutomationId="Command.Surface"
                AutomationProperties.Name="Search and commands modal">
            <Border Style="{StaticResource LifeOS.Card}"
                    Width="620"
                    VerticalAlignment="Top"
                    Margin="0,138,0,0"
                    FocusManager.IsFocusScope="True"
                    KeyboardNavigation.TabNavigation="Cycle"
                    KeyboardNavigation.ControlTabNavigation="Cycle"
                    KeyboardNavigation.DirectionalNavigation="Contained">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Search and commands"/>
                    <TextBox x:Name="CommandTextBox"
                             Margin="0,14,0,12"
                             Padding="12,10"
                             FontSize="15"
                             KeyDown="CommandTextBox_KeyDown"
                             AutomationProperties.AutomationId="Command.Input"/>
                    <TextBlock Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" TextWrapping="Wrap" Text="Try: Home, Work, Career, Money, Life, Projects, Assistant, Settings, Theme light, Theme dark, Density compact, Density comfortable, Legacy"/>
                    <Button Margin="0,14,0,0" HorizontalAlignment="Left" Style="{StaticResource LifeOS.FocusableButton}" Content="Close" Click="CloseCommand_Click" AutomationProperties.AutomationId="Command.Close"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
