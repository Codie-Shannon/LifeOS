<Window x:Class="LifeOS.TimerAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Life OS TimerAgent"
        Height="680"
        Width="520"
        MinHeight="620"
        MinWidth="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#0F172A">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Life OS TimerAgent"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"/>

            <TextBlock Text="Track contractor work, earned income, and tax set-aside."
                       Foreground="#CBD5E1"
                       FontSize="14"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Timer display -->
        <Border Grid.Row="2"
                Background="#111827"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="18"
                Padding="22">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="TimerDisplay"
                           Text="00:00:00"
                           Foreground="White"
                           FontSize="48"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="StateDisplay"
                           Text="Stopped"
                           Foreground="#94A3B8"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                <UniformGrid Columns="3"
                             Margin="0,22,0,0">
                    <Button x:Name="StartButton"
                            Content="Start"
                            Height="44"
                            Margin="4"
                            Click="StartButton_Click"/>

                    <Button x:Name="PauseResumeButton"
                            Content="Pause"
                            Height="44"
                            Margin="4"
                            IsEnabled="False"
                            Click="PauseResumeButton_Click"/>

                    <Button x:Name="StopButton"
                            Content="Stop"
                            Height="44"
                            Margin="4"
                            IsEnabled="False"
                            Click="StopButton_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- Session fields -->
        <Border Grid.Row="4"
                Background="#111827"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Client"
                           Foreground="#CBD5E1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="ClientTextBox"
                         Grid.Row="0" Grid.Column="1"
                         Text="AIE"
                         Height="34"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Project"
                           Foreground="#CBD5E1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="ProjectTextBox"
                         Grid.Row="2" Grid.Column="1"
                         Text="INFO mailbox"
                         Height="34"/>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="Work type"
                           Foreground="#CBD5E1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="WorkTypeTextBox"
                         Grid.Row="4" Grid.Column="1"
                         Text="Workflow/Admin"
                         Height="34"/>

                <TextBlock Grid.Row="6" Grid.Column="0"
                           Text="Rate"
                           Foreground="#CBD5E1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="RateTextBox"
                         Grid.Row="6" Grid.Column="1"
                         Text="35"
                         Height="34"/>

                <TextBlock Grid.Row="8" Grid.Column="0"
                           Text="Tax %"
                           Foreground="#CBD5E1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="TaxTextBox"
                         Grid.Row="8" Grid.Column="1"
                         Text="20"
                         Height="34"/>

                <CheckBox x:Name="BillableCheckBox"
                          Grid.Row="10" Grid.Column="1"
                          Content="Billable"
                          Foreground="#CBD5E1"
                          IsChecked="True"/>
            </Grid>
        </Border>

        <!-- Notes and totals -->
        <Border Grid.Row="6"
                Background="#111827"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Notes"
                           Foreground="#CBD5E1"/>

                <TextBox x:Name="NotesTextBox"
                         Grid.Row="2"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <TextBlock x:Name="EarnedDisplay"
                           Grid.Row="4"
                           Text="Earned: $0.00"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <TextBlock x:Name="TaxDisplay"
                           Grid.Row="6"
                           Text="Tax set-aside: $0.00"
                           Foreground="#FBBF24"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <TextBlock x:Name="SafeAfterTaxDisplay"
                           Grid.Row="8"
                           Text="Safe after tax: $0.00"
                           Foreground="#86EFAC"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <TextBlock x:Name="LogPathDisplay"
                           Grid.Row="10"
                           Text=""
                           Foreground="#94A3B8"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>