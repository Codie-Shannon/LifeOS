<Window x:Class="LifeOS.TimerAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Life OS TimerAgent"
        Height="720"
        Width="560"
        MinHeight="640"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="LifeButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6" />
                                <Setter Property="BorderBrush" Value="#9CA3AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F9FAFB" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                                <Setter Property="BorderBrush" Value="#E5E7EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource LifeButton}">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SoftButton" TargetType="Button" BasedOn="{StaticResource LifeButton}">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#C7D2FE" />
            <Setter Property="Foreground" Value="#1E40AF" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource LifeButton}">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#DC2626" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="QuietDangerButton" TargetType="Button" BasedOn="{StaticResource LifeButton}">
            <Setter Property="Background" Value="#FEF2F2" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="Foreground" Value="#991B1B" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="#111827" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <DataTemplate x:Key="TimedTaskTemplate">
            <Border Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="#111827"
                               FontSize="15"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding WorkType}"
                               Foreground="#2563EB"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <WrapPanel Grid.Row="4">
                        <TextBlock Text="{Binding ContactName}" Foreground="#6B7280" FontSize="12" />
                        <TextBlock Text=" · " Foreground="#9CA3AF" FontSize="12" />
                        <TextBlock Text="{Binding State}" Foreground="#6B7280" FontSize="12" />
                        <TextBlock Text=" · $" Foreground="#9CA3AF" FontSize="12" />
                        <TextBlock Text="{Binding HourlyRate}" Foreground="#6B7280" FontSize="12" />
                        <TextBlock Text="/h · tax " Foreground="#9CA3AF" FontSize="12" />
                        <TextBlock Text="{Binding TaxSetAsidePercent}" Foreground="#6B7280" FontSize="12" />
                        <TextBlock Text="%" Foreground="#6B7280" FontSize="12" />
                    </WrapPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ContactTemplate">
            <Border Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="#111827"
                               FontSize="15"
                               FontWeight="Bold" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding Type}"
                               Foreground="#2563EB"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="4"
                               Text="{Binding DefaultWorkType}"
                               Foreground="#6B7280"
                               FontSize="12" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#F5F7FB"
            BorderBrush="#D1D5DB"
            BorderThickness="1"
            CornerRadius="24">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    CornerRadius="18"
                    Padding="16,14"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Life OS TimerAgent"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Timed tasks, people, billable time, tax set-aside"
                                   Foreground="#CBD5E1"
                                   FontSize="12"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Hide"
                            Width="74"
                            Height="36"
                            Style="{StaticResource SoftButton}"
                            Click="HideWindowButton_Click" />
                </Grid>
            </Border>

            <UniformGrid Grid.Row="2" Columns="3">
                <Button Content="List"
                        Height="40"
                        Margin="3"
                        Style="{StaticResource SoftButton}"
                        Click="ListNavButton_Click" />
                <Button Content="Timer"
                        Height="40"
                        Margin="3"
                        Style="{StaticResource SoftButton}"
                        Click="TimerNavButton_Click" />
                <Button Content="People"
                        Height="40"
                        Margin="3"
                        Style="{StaticResource SoftButton}"
                        Click="ContactsNavButton_Click" />
            </UniformGrid>

            <Grid Grid.Row="4">
                <Grid x:Name="ListPage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Timed tasks"
                               Foreground="#111827"
                               FontSize="20"
                               FontWeight="Bold" />

                    <Button Grid.Row="2"
                            Content="+ Create timed task"
                            Height="42"
                            Style="{StaticResource PrimaryButton}"
                            Click="CreateTaskButton_Click" />

                    <ListBox x:Name="TimedTasksListBox"
                             Grid.Row="4"
                             ItemTemplate="{StaticResource TimedTaskTemplate}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="TimedTasksListBox_SelectionChanged" />

                    <UniformGrid Grid.Row="6" Columns="3">
                        <Button x:Name="ListStartPauseButton"
                                Content="Start"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource PrimaryButton}"
                                Click="ListStartPauseButton_Click" />
                        <Button x:Name="ListStopButton"
                                Content="Stop"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource DangerButton}"
                                Click="ListStopButton_Click" />
                        <Button Content="Edit"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource LifeButton}"
                                Click="EditTaskButton_Click" />
                    </UniformGrid>
                </Grid>

                <Grid x:Name="TimerPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock x:Name="ActiveTaskNameText"
                                       Text="No timed task selected"
                                       Foreground="#111827"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ActiveTaskMetaText"
                                       Text="Select a task from the list"
                                       Foreground="#6B7280"
                                       FontSize="13"
                                       Margin="0,6,0,0" />
                            <TextBlock x:Name="TimerDisplay"
                                       Text="00:00:00"
                                       Foreground="#111827"
                                       FontSize="52"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,8" />
                            <TextBlock x:Name="StateDisplay"
                                       Text="Stopped"
                                       Foreground="#2563EB"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="CompactMoneyDisplay"
                                       Text="$0.00 earned · $0.00 tax · $0.00 safe"
                                       Foreground="#374151"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <UniformGrid Grid.Row="2" Columns="3">
                        <Button x:Name="StartButton"
                                Content="Start"
                                Height="44"
                                Margin="3"
                                Style="{StaticResource PrimaryButton}"
                                Click="StartButton_Click" />
                        <Button x:Name="PauseResumeButton"
                                Content="Pause"
                                Height="44"
                                Margin="3"
                                Style="{StaticResource LifeButton}"
                                Click="PauseResumeButton_Click" />
                        <Button x:Name="StopButton"
                                Content="Stop"
                                Height="44"
                                Margin="3"
                                Style="{StaticResource DangerButton}"
                                Click="StopButton_Click" />
                    </UniformGrid>

                    <Border Grid.Row="4" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Totals"
                                       Foreground="#111827"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <UniformGrid Grid.Row="2" Columns="3">
                                <StackPanel Margin="3">
                                    <TextBlock Text="Today" Style="{StaticResource MutedText}" />
                                    <TextBlock x:Name="TodayTotalsText" Text="0h · $0.00" FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel Margin="3">
                                    <TextBlock Text="This week" Style="{StaticResource MutedText}" />
                                    <TextBlock x:Name="WeekTotalsText" Text="0h · $0.00" FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel Margin="3">
                                    <TextBlock Text="All time" Style="{StaticResource MutedText}" />
                                    <TextBlock x:Name="AllTotalsText" Text="0h · $0.00" FontWeight="Bold" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="ContactsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="People / contacts"
                               Foreground="#111827"
                               FontSize="20"
                               FontWeight="Bold" />

                    <Button Grid.Row="2"
                            Content="+ Create contact"
                            Height="42"
                            Style="{StaticResource PrimaryButton}"
                            Click="CreateContactButton_Click" />

                    <ListBox x:Name="ContactsListBox"
                             Grid.Row="4"
                             ItemTemplate="{StaticResource ContactTemplate}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="ContactsListBox_SelectionChanged" />

                    <UniformGrid Grid.Row="6" Columns="3">
                        <Button Content="Use"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource PrimaryButton}"
                                Click="SelectContactButton_Click" />
                        <Button Content="Edit"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource LifeButton}"
                                Click="EditContactButton_Click" />
                        <Button Content="Archive"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource QuietDangerButton}"
                                Click="ArchiveContactButton_Click" />
                    </UniformGrid>
                </Grid>

                <Grid x:Name="TaskDetailsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TaskDetailsTitle"
                               Grid.Row="0"
                               Text="Create timed task"
                               Foreground="#111827"
                               FontSize="20"
                               FontWeight="Bold" />

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Task name" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="TaskNameTextBox" Margin="0,6,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Contact / person / organisation" Style="{StaticResource LabelText}" />
                                <ComboBox x:Name="TaskContactComboBox"
                                          DisplayMemberPath="DisplayName"
                                          Margin="0,6,0,0"
                                          SelectionChanged="TaskContactComboBox_SelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="Project" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="TaskProjectTextBox" Margin="0,6,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="6">
                                <TextBlock Text="Work type" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="TaskWorkTypeTextBox" Margin="0,6,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Task type" Style="{StaticResource LabelText}" />
                                    <ComboBox x:Name="TaskTypeComboBox" Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Mode" Style="{StaticResource LabelText}" />
                                    <ComboBox x:Name="TaskModeComboBox" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Hourly rate" Style="{StaticResource LabelText}" />
                                    <TextBox x:Name="TaskRateTextBox" Text="35" Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tax %" Style="{StaticResource LabelText}" />
                                    <TextBox x:Name="TaskTaxTextBox" Text="20" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>

                            <CheckBox x:Name="TaskBillableCheckBox"
                                      Grid.Row="12"
                                      Content="Billable"
                                      IsChecked="True" />
                        </Grid>
                    </ScrollViewer>

                    <UniformGrid Grid.Row="4" Columns="3">
                        <Button Content="Save"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource PrimaryButton}"
                                Click="SaveTaskButton_Click" />
                        <Button Content="Archive"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource QuietDangerButton}"
                                Click="ArchiveTaskButton_Click" />
                        <Button Content="Cancel"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource LifeButton}"
                                Click="CancelDetailsButton_Click" />
                    </UniformGrid>
                </Grid>

                <Grid x:Name="ContactDetailsPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ContactDetailsTitle"
                               Grid.Row="0"
                               Text="Create contact"
                               Foreground="#111827"
                               FontSize="20"
                               FontWeight="Bold" />

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Display name" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="ContactNameTextBox" Margin="0,6,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Type" Style="{StaticResource LabelText}" />
                                <ComboBox x:Name="ContactTypeComboBox" Margin="0,6,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="4">
                                <TextBlock Text="Default work type" Style="{StaticResource LabelText}" />
                                <TextBox x:Name="ContactDefaultWorkTypeTextBox" Margin="0,6,0,0" />
                            </StackPanel>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Default rate" Style="{StaticResource LabelText}" />
                                    <TextBox x:Name="ContactDefaultRateTextBox" Text="35" Margin="0,6,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Default tax %" Style="{StaticResource LabelText}" />
                                    <TextBox x:Name="ContactDefaultTaxTextBox" Text="20" Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>

                    <UniformGrid Grid.Row="4" Columns="2">
                        <Button Content="Save"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource PrimaryButton}"
                                Click="SaveContactButton_Click" />
                        <Button Content="Cancel"
                                Height="42"
                                Margin="3"
                                Style="{StaticResource LifeButton}"
                                Click="CancelDetailsButton_Click" />
                    </UniformGrid>
                </Grid>
            </Grid>

            <Border Grid.Row="6"
                    Background="#E5E7EB"
                    CornerRadius="14"
                    Padding="12,8">
                <TextBlock x:Name="StatusStripText"
                           Text="No active timed task"
                           Foreground="#374151"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Border>
</Window>