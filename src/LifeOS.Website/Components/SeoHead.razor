<PageTitle>@Title · LifeOS</PageTitle>
<HeadContent>
  <meta name="description" content="@Description" />
  <meta property="og:title" content="@Title · LifeOS" />
  <meta property="og:description" content="@Description" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href="@CanonicalPath" />
</HeadContent>
@code { [Parameter, EditorRequired] public string Title { get; set; } = "LifeOS"; [Parameter, EditorRequired] public string Description { get; set; } = PublicContent.PrimaryMessage; [Parameter] public string CanonicalPath { get; set; } = "/"; }
