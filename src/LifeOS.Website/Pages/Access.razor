@page "/access"
<SeoHead Title="Early Access" Description="LifeOS early-access requests are not yet open; no personal data is collected by this preview." CanonicalPath="/access" />
<PageIntro Eyebrow="Early Access" Title="Access requests are opening later." Summary="This preview shows the intended minimal contract. Submission remains disabled until a real storage path, handling policy and contact method are configured." />
<section class="page-shell section"><div class="access-layout"><form class="access-form" aria-describedby="access-state" @onsubmit:preventDefault><div class="form-state"><StatusBadge Text="Preview only · no collection" Kind="warning" /><p id="access-state">No details entered here are sent, stored or retained.</p></div><label>Name<input disabled placeholder="Your name" /></label><label>Email<input disabled type="email" placeholder="you@example.com" /></label><label>Audience type<select disabled><option>Select one</option><option>Business</option><option>Individual</option><option>Technical reviewer</option></select></label><label>Optional short reason<textarea disabled rows="4" placeholder="What would you like to evaluate?"></textarea></label><button class="button primary" disabled>Requests opening later</button></form><aside><p class="eyebrow">Honest boundary</p><h2>No disappearing submissions.</h2><p>LifeOS will not accept personal data until the submission destination, purpose, retention approach and privacy wording are real and documented.</p><a href="/privacy">Read the Privacy page <span aria-hidden="true">→</span></a></aside></div></section>
