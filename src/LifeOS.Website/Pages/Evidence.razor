@page "/evidence"
<SeoHead Title="Evidence and Development Proof" Description="Inspect LifeOS tests, builds, scans, screenshots, release discipline and defects fixed." CanonicalPath="/evidence" />
<PageIntro Eyebrow="Evidence · Development Proof" Title="The product should be judged by what can be inspected." Summary="LifeOS presents release state, validation, architecture decisions and defects fixed without exposing private client data or local records." />
<section class="proof-strip standalone"><div class="page-shell proof-grid">@foreach (var metric in PublicContent.ProofMetrics) { <article><strong>@metric.Value</strong><span>@metric.Label</span><small>@metric.Detail</small></article> }</div></section>
<section class="page-shell section"><div class="evidence-columns"><article><p class="eyebrow">Release proof</p><h2>Baseline state</h2><ul class="check-list"><li>Desktop v7.0.0-beta.1 complete</li><li>Companion v0.1.0-beta.1 complete</li><li>Website v0.1.0-alpha.1 foundation</li><li>Full Mobile remains planned</li></ul></article><article><p class="eyebrow">Repository proof</p><h2>Release gates</h2><ul class="check-list"><li>Release builds</li><li>Automated tests</li><li>NuGet vulnerability scan</li><li>Gitleaks secret scan</li><li>Clean synchronization</li></ul></article></div></section>
<section class="page-shell section"><div class="defect-panel"><div><p class="eyebrow">Real defects, real re-verification</p><h2>Testing is allowed to find problems.</h2><p>LifeOS records defects discovered through beta and real-device testing, applies a bounded fix and verifies the affected behavior again. That is stronger evidence than pretending the first build was perfect.</p></div><div class="defect-flow"><span>FOUND</span><b>→</b><span>BOUNDED</span><b>→</b><span>FIXED</span><b>→</b><span>RE-VERIFIED</span></div></div></section>
<section class="page-shell section"><SafetyCallout Label="Public evidence boundary" Title="Fictional or sanitized identities only." Text="Public demonstrations use approved fictional or sanitized records. Private client data, local endpoints, secrets and raw logs are excluded." /></section>
