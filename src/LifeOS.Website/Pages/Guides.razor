@page "/docs/guides"
<SeoHead Title="Guides" Description="Practical LifeOS starting points and recovery guidance." CanonicalPath="/docs/guides" />
<PageIntro Eyebrow="Docs · Guides" Title="Guides" Summary="Task-oriented starting points for users, including Companion use and safe recovery." />
<section class="page-shell section"><div class="search-results">@foreach (var item in PublicContent.Docs.Where(x => x.Category is "Guide" or "Troubleshooting")) { <a class="search-result-card" href="@item.Route"><div><span class="doc-type">@item.Audience · @item.Product · @item.Version</span><h2>@item.Title</h2><p>@item.Summary</p><small>Updated @item.Updated.ToString("yyyy-MM-dd")</small></div><span>→</span></a> }</div></section>
