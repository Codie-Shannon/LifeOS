@page "/docs/guides"
<SeoHead Title="Guides" Description="Practical starting points for users and technical reviewers." CanonicalPath="/docs/guides" />
<PageIntro Eyebrow="Docs · Guides" Title="Guides" Summary="Practical starting points for users and technical reviewers." />
<section class="page-shell section"><div class="search-results">@foreach (var item in PublicContent.Docs.Where(x => x.Category == "Guide")) { <a class="search-result-card" href="@item.Route"><div><span class="doc-type">@item.Audience · @item.Product · @item.Version</span><h2>@item.Title</h2><p>@item.Summary</p><small>Updated @item.Updated.ToString("yyyy-MM-dd")</small></div><span aria-hidden="true">→</span></a> }</div></section>