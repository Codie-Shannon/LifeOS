@page "/"
<SeoHead Title="Local-first personal operating system" Description="@PublicContent.PrimaryMessage" />
<section class="hero page-shell">
  <div class="hero-copy"><p class="eyebrow">LifeOS · visible state under pressure</p><h1>Turn daily pressure into <span>visible, reviewable state.</span></h1><p class="lead">@PublicContent.PrimaryMessage</p><div class="hero-actions"><a class="button primary" href="/product">Explore Product</a><a class="button secondary" href="/evidence">View Evidence</a><a class="text-link" href="/access">Join Early Access <span aria-hidden="true">→</span></a></div></div>
  <div class="hero-visual" aria-label="Illustration of LifeOS operating state"><div class="visual-top"><span>OPERATING STATE</span><StatusBadge Text="REVIEW READY" Kind="success" /></div><div class="pressure-line"><span>Daily pressure</span><div></div><strong>Visible state</strong></div><div class="state-grid"><article><small>NEXT ACTION</small><strong>Review active work</strong><span>3 decisions visible</span></article><article><small>MONEY</small><strong>Proof before invoice</strong><span>Evidence linked</span></article><article><small>PROJECTS</small><strong>One current milestone</strong><span>Scope guarded</span></article><article><small>FOLLOW-UPS</small><strong>No silent drops</strong><span>2 awaiting review</span></article></div><div class="visual-footer"><span>LOCAL-FIRST</span><span>REVIEW-FIRST</span><span>EVIDENCE-DRIVEN</span></div></div>
</section>
<section class="proof-strip"><div class="page-shell proof-grid">@foreach (var metric in PublicContent.ProofMetrics) { <article><strong>@metric.Value</strong><span>@metric.Label</span><small>@metric.Detail</small></article> }</div></section>
<section class="section page-shell"><div class="section-heading"><p class="eyebrow">Choose your path</p><h2>One product story. Three useful entry points.</h2></div><div class="card-grid three">@foreach (var audience in PublicContent.Audiences) { <a class="audience-card" href="@audience.Route"><span class="card-signal">@audience.Signal</span><h3>@audience.Name</h3><p>@audience.Summary</p><span class="card-link">Explore <b aria-hidden="true">→</b></span></a> }</div></section>
<section class="section page-shell"><div class="split-heading"><div><p class="eyebrow">Current platform state</p><h2>Real products, clear boundaries.</h2></div><p>Desktop and Companion have completed beta baselines. Full Mobile remains a separate planned product track.</p></div><div class="product-grid">@foreach (var product in PublicContent.Products) { <article class="product-card"><div><StatusBadge Text="@product.State" Kind="@(product.State == "Planned" ? "warning" : "success")" /><span class="version">@product.Version</span></div><h3>@product.Name</h3><p>@product.Summary</p><a href="@product.Route">View product <span aria-hidden="true">→</span></a></article> }</div></section>
<section class="section page-shell"><SafetyCallout Label="Safety philosophy" Title="Local-first. Review-first. Evidence-driven." Text="LifeOS keeps ownership close, makes consequential decisions reviewable and treats proof as part of the work—not an afterthought." /></section>
<section class="section page-shell roadmap-teaser"><div><p class="eyebrow">Roadmap</p><h2>Website beta ready. Desktop v8 redesign comes next.</h2><p>The public product site, documentation system, evidence surface and deployment workflow are now ready for launch-readiness review. Desktop remains unchanged until Group 43.</p></div><a class="button secondary" href="/roadmap">View Roadmap</a></section>
