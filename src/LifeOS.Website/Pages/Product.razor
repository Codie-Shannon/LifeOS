@page "/product"
<SeoHead Title="Product" Description="Explore the LifeOS Desktop, Mobile Companion and planned Full Mobile product boundaries." CanonicalPath="/product" />
<PageIntro Eyebrow="Product" Title="A platform split by purpose, not by marketing." Summary="Desktop is the full operating environment. Mobile Companion is intentionally lightweight. Full Mobile is a separate planned application." />
<section class="page-shell section"><div class="product-grid">@foreach (var product in PublicContent.Products) { <article class="product-card large"><div><StatusBadge Text="@product.State" Kind="@(product.State == "Planned" ? "warning" : "success")" /><span class="version">@product.Version</span></div><h2>@product.Name</h2><p>@product.Summary</p><a href="@product.Route">Explore @product.Name <span aria-hidden="true">→</span></a></article> }</div></section>
<section class="page-shell section"><div class="principle-grid"><article><span>01</span><h2>Local-first</h2><p>Private operating records remain on the user-controlled device unless a future feature explicitly says otherwise.</p></article><article><span>02</span><h2>Review-first</h2><p>Consequential actions should remain visible, bounded and confirmable instead of disappearing into automation.</p></article><article><span>03</span><h2>Evidence-driven</h2><p>Tests, screenshots, release checks and defect records support claims with inspectable proof.</p></article></div></section>
